# Normalize line endings: store everything as LF in the repo.
# This stops the "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Source & text files — always LF
*.java   text eol=lf
*.xml    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.properties text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf

# Windows-specific scripts keep CRLF
*.cmd    text eol=crlf
*.bat    text eol=crlf

# Shell scripts must stay LF to remain executable
*.sh     text eol=lf
mvnw     text eol=lf

# Binary files — never touch
*.jar    binary
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.zip    binary
*.gz     binary
